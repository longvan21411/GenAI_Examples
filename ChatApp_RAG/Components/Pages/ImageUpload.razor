@page "/image-upload"
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@inject QdrantImageService ImageService

<h3>Image Upload</h3>
<p>Upload images to associate with the assistant.</p>
<InputFile OnChange="OnInputFileChange" multiple />

@if (uploadedImages.Any())
{
    <div class="image-grid">
        @foreach (var img in uploadedImages)
        {
            <div class="image-cell">
                <img src="@img.DataUrl" alt="@img.Name" />               
            </div>
        }
    </div>
}

<div class="upload-controls">    
    <div class="upload-meta">
        <br>
        <label class="meta-field">
            <div class="meta-label">Category</div>
            <select @bind="selectedCategory">
                <option value="">-- Select category --</option>
                <option value="Cat">Cat</option>
                <option value="Dog">Dog</option>
                <option value="Wild animals">Wild animals</option>
            </select>
        </label>
        <br>
        <label class="meta-field">
            <div class="meta-label">Description</div>
            <textarea @bind="description" rows="7" placeholder="Optional description..."></textarea>
        </label>
        <br>
        <div class="action-bar">
            <button class="btn-default" @onclick="OnAddImagesAsync" disabled="@(uploadedImages.Count == 0)">Add images</button>
            <button class="btn-subtle" @onclick="OnCancelSelection" disabled="@(uploadedImages.Count == 0)">Cancel</button>
        </div>
    </div>
</div>

@if (messages.Count > 0)
{
    <div class="upload-messages">
        @foreach (var message in messages)
        {
            <div>@message</div>
        }
    </div>
}



@code {
    private const long MaxFileSize = 5 * 1024 * 1024; // 5 MB
    private readonly List<UploadedImage> uploadedImages = new();
    private readonly List<string> messages = new();

    private string selectedCategory = string.Empty;
    private string description = string.Empty;

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        messages.Clear();

        foreach (var file in e.GetMultipleFiles())
        {
            var name = file.Name ?? "(unnamed)";
            var ext = Path.GetExtension(name)?.ToLowerInvariant() ?? string.Empty;

            if (ext != ".jpg" && ext != ".png")
            {
                messages.Add($"Skipped '{name}': only .jpg and .png files are allowed.");
                continue;
            }

            if (file.Size > MaxFileSize)
            {
                messages.Add($"'{name}' exceeds the maximum size of {FormatBytes(MaxFileSize)} (selected: {FormatBytes(file.Size)}).");
                continue;
            }

            try
            {
                // Read file into memory and convert to data URL for display
                using var ms = new MemoryStream();
                // Limit stream to MaxFileSize to protect from large files
                await file.OpenReadStream(MaxFileSize).CopyToAsync(ms);
                var bytes = ms.ToArray();
                var base64 = Convert.ToBase64String(bytes);
                var contentType = file.ContentType ?? (ext == ".png" ? "image/png" : "image/jpeg");
                var dataUrl = $"data:{contentType};base64,{base64}";

                uploadedImages.Add(new UploadedImage
                {
                    Name = name,
                    DataUrl = dataUrl,
                    Size = file.Size,
                    Content = bytes,
                    ContentType = contentType
                });
            }
            catch (Exception ex)
            {
                messages.Add($"Failed to load '{name}': {ex.Message}");
            }
        }

        StateHasChanged();
    }

    private Task OnAddImagesAsync() => SaveImagesAsync();

    private async Task SaveImagesAsync()
    {
        foreach (var img in uploadedImages)
        {
            if (img.IsConfirmed)
            {
                continue;
            }

            try
            {
                var result = await ImageService.StoreImageAsync(
                    img.Name,
                    img.ContentType,
                    img.Content,
                    description,
                    selectedCategory);

                img.IsConfirmed = true;
                img.Category = selectedCategory;
                img.Description = result.Description;
                img.StoredPath = result.RelativePath;
                img.PointId = result.PointId;
                messages.Insert(0, $"Stored '{img.Name}' to '{result.RelativePath}' and upserted Qdrant point {result.PointId}.");
            }
            catch (Exception ex)
            {
                messages.Insert(0, $"Failed to store '{img.Name}': {ex.Message}");
            }
        }

        StateHasChanged();
    }

    private void OnCancelSelection()
    {
        uploadedImages.Clear();
        messages.Insert(0, "Image selection canceled.");
        StateHasChanged();
    }

    private void OnFindSimilarity(UploadedImage img)
    {
        // Placeholder: wire up similarity search or other action here.
        messages.Insert(0, $"Find Similarity clicked for '{img.Name}'.");
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1 << 30) return $"{bytes / (1 << 30)} GB";
        if (bytes >= 1 << 20) return $"{bytes / (1 << 20)} MB";
        if (bytes >= 1 << 10) return $"{bytes / (1 << 10)} KB";
        return $"{bytes} B";
    }

    private class UploadedImage
    {
        public string Name { get; set; } = string.Empty;
        public string DataUrl { get; set; } = string.Empty;
        public long Size { get; set; }
        public byte[] Content { get; set; } = [];
        public string ContentType { get; set; } = string.Empty;
        public bool IsConfirmed { get; set; }
        public string Category { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string StoredPath { get; set; } = string.Empty;
        public Guid? PointId { get; set; }
    }
}
