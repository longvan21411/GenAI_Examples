@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject NavigationManager Nav

<header class="main-header">
    <div class="page-width">
        <div class="header-left">
            <div class="app-left">
                <img src="/img/QCbot_0.jpeg" class="app-logo" alt="QCbot logo"/>
                <div class="app-title">ChatApp RAG</div>
            </div>
        </div>

        <div class="header-right">
            <button class="theme-toggle btn-subtle" @onclick="ToggleThemeAsync" title="Toggle dark / light mode">@themeIcon</button>
        </div>
    </div>
</header>

<div class="app-shell">
    <aside class="left-panel">
        <div class="left-actions">
            <button class="btn-default" @onclick="GoHome">New chat</button>
            <button class="btn-default" @onclick="GoImage">Add new image</button>
        </div>
    </aside>

    <main class="content-area page-width">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<script src="/js/theme.js"></script>

@code {
    private string themeIcon = "🌙";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var isDark = await JS.InvokeAsync<bool>("theme.init");
                themeIcon = isDark ? "☀️" : "🌙";
                StateHasChanged();
            }
            catch
            {
            }
        }
    }

    private async Task ToggleThemeAsync()
    {
        try
        {
            var isDark = await JS.InvokeAsync<bool>("theme.toggle");
            themeIcon = isDark ? "☀️" : "🌙";
        }
        catch
        {
        }
    }

    private void GoHome()
    {
        Nav.NavigateTo("/");
    }

    private void GoImage()
    {
        Nav.NavigateTo("/image-upload");
    }
}
